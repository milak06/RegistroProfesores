@model T1_POOII.Models.Profesor
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Editar Profesor</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-card">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.DNI)

        <div class="form-group">
            @Html.LabelFor(model => model.Nombre)
            @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Apellidos)
            @Html.EditorFor(model => model.Apellidos, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Apellidos, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Carrera)
            @Html.EditorFor(model => model.Carrera, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Carrera, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Correo)
            @Html.EditorFor(model => model.Correo, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Correo, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Edad)
            @Html.EditorFor(model => model.Edad, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Edad, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Sueldo)
            @Html.EditorFor(model => model.Sueldo, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Sueldo, "", new { @class = "text-danger" })
        </div>

        <div class="form-botones">
            <input type="submit" value="Guardar cambios" class="btn-guardar" />
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-cancelar" })
        </div>
    </div>
}

<style>
    h2 {
        text-align: center;
        margin-bottom: 30px;
    }

    .form-card {
        max-width: 550px;
        margin: 0 auto;
        background-color: #fff;
        border-radius: 12px;
        padding: 35px 40px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 18px;
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            font-weight: bold;
            margin-bottom: 5px;
            color: #0288D1;
        }

        .form-group .form-control {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 0.95rem;
            transition: border-color 0.3s ease;
        }

            .form-group .form-control:focus {
                border-color: #29B6F6;
                outline: none;
                box-shadow: 0 0 5px rgba(41,182,246,0.4);
            }

    .form-botones {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
    }

    .btn-guardar {
        background-color: #29B6F6;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
        box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }

        .btn-guardar:hover {
            background-color: #0288D1;
            transform: scale(1.05);
        }

    .btn-cancelar {
        color: #555;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.3s ease;
    }

        .btn-cancelar:hover {
            color: #0288D1;
        }

    .text-danger {
        color: #e53935;
        font-size: 0.85rem;
        margin-top: 3px;
    }
</style>